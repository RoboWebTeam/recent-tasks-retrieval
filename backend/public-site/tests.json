{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET without slug returns 400",
      "method": "GET",
      "path": "/",
      "expectedStatus": 400
    },
    {
      "name": "GET with unknown slug returns 404",
      "method": "GET",
      "path": "/?slug=unknown-slug-xyz",
      "expectedStatus": 404
    }
  ]
}
