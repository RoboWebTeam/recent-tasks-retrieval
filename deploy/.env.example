# Скопируйте этот файл в deploy/.env и заполните реальными значениями.
# Заполните реальными значениями секретов.

# --- Адрес вашего сайта (используется при сборке фронтенда) ---
SITE_URL=https://roboweb.site

# --- PostgreSQL (используется контейнером db и backend) ---
POSTGRES_DB=roboweb
POSTGRES_USER=roboweb_user
POSTGRES_PASSWORD=замените-на-надёжный-пароль

# Backend подключается к БД по имени контейнера "db" (см. docker-compose.yml)
DATABASE_URL=postgresql://roboweb_user:замените-на-надёжный-пароль@db:5432/roboweb
MAIN_DB_SCHEMA=public

# --- Файловое хранилище (S3-совместимое: imbacloud/hostkey, reg.ru и т.п.) ---
# Эндпоинт и регион провайдера. Пример imbacloud (RU): https://s3-ru.hostkey.ru + ru
S3_ENDPOINT_URL=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Публичная база для ссылок на файлы (обычно <endpoint>/<bucket>). Пусто — соберётся автоматически.
S3_PUBLIC_BASE=
# ACL при загрузке: public-read или пусто, если публичность задаётся политикой бакета.
S3_ACL=public-read

# --- AI-провайдеры ---
OPENROUTER_API_KEY=

# --- Почта ---
SMTP_PASSWORD=

# --- OAuth ---
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Платежи ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# --- Админка ---
ADMIN_KEY=